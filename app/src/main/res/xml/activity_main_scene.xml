<?xml version="1.0" encoding="utf-8"?>
<MotionScene 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:motion="http://schemas.android.com/apk/res-auto">

    <Transition
        motion:constraintSetEnd="@+id/chat"
        motion:constraintSetStart="@id/start"
        motion:duration="500">
        <KeyFrameSet>
        </KeyFrameSet>
    </Transition>

    <ConstraintSet android:id="@+id/start">
        <Constraint
            android:id="@+id/mainImageView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            motion:layout_constraintTop_toTopOf="parent"
            motion:layout_constraintBottom_toTopOf="@+id/bottomCard">
            <CustomAttribute
                motion:attributeName="roundPercent"
                motion:customFloatValue="0.0" />
        </Constraint>

        <Constraint
            android:id="@+id/bottomCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            motion:layout_constraintBottom_toBottomOf="parent"
            android:translationY="0dp" />

        <Constraint
            android:id="@+id/closeChatButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="48dp"
            motion:layout_constraintStart_toStartOf="parent"
            motion:layout_constraintTop_toTopOf="parent"
            android:alpha="0"
            android:visibility="gone" />

        <Constraint
            android:id="@+id/chatPlantNameTextView"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="48dp"
            android:layout_marginEnd="16dp"
            motion:layout_constraintStart_toEndOf="@+id/closeChatButton"
            motion:layout_constraintTop_toTopOf="parent"
            motion:layout_constraintEnd_toStartOf="@+id/mainImageView"
            android:alpha="0"
            android:visibility="gone" />

        <Constraint
            android:id="@+id/chatResponseScrollView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="16dp"
            motion:layout_constraintTop_toBottomOf="@+id/mainImageView"
            motion:layout_constraintBottom_toBottomOf="parent"
            motion:layout_constraintStart_toStartOf="parent"
            motion:layout_constraintEnd_toEndOf="parent"
            android:alpha="0"
            android:visibility="gone" />
    </ConstraintSet>

    <ConstraintSet android:id="@+id/chat">
        <Constraint
            android:id="@+id/mainImageView"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_marginTop="48dp"
            android:layout_marginEnd="16dp"
            motion:layout_constraintTop_toTopOf="parent"
            motion:layout_constraintEnd_toEndOf="parent">
            <CustomAttribute
                motion:attributeName="roundPercent"
                motion:customFloatValue="1.0" />
        </Constraint>

        <!-- Slide the bottom card entirely out of the screen downwards -->
        <Constraint
            android:id="@+id/bottomCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            motion:layout_constraintTop_toBottomOf="parent" />

        <Constraint
            android:id="@+id/closeChatButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="48dp"
            motion:layout_constraintStart_toStartOf="parent"
            motion:layout_constraintTop_toTopOf="parent"
            android:alpha="1"
            android:visibility="visible" />

        <Constraint
            android:id="@+id/chatPlantNameTextView"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="48dp"
            android:layout_marginEnd="16dp"
            motion:layout_constraintStart_toEndOf="@+id/closeChatButton"
            motion:layout_constraintTop_toTopOf="parent"
            motion:layout_constraintEnd_toStartOf="@+id/mainImageView"
            android:alpha="1"
            android:visibility="visible" />

        <Constraint
            android:id="@+id/chatResponseScrollView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="16dp"
            motion:layout_constraintTop_toBottomOf="@+id/mainImageView"
            motion:layout_constraintBottom_toBottomOf="parent"
            motion:layout_constraintStart_toStartOf="parent"
            motion:layout_constraintEnd_toEndOf="parent"
            android:alpha="1"
            android:visibility="visible" />
    </ConstraintSet>

</MotionScene>
